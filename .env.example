# NeNetflixBot Configuration Example
# Rename this file to .env and fill in your values

# 1. Telegram Bot Token
BOT_TOKEN=your_bot_token_here

# 2. TMDB API Key (v3)
TMDB_API_KEY=your_tmdb_api_key_here

# 3. Channel Settings
CHANNEL_ID=-100xxxxxxxxxx
CHANNEL_USERNAME=@your_channel_username

# 4. Admin Settings
ADMIN_ID=your_id_here
ADMIN_IDS=id1,id2

# 5. Services API Keys (Optional/Mocked)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...

# 6. Payment (Mock/Monobank)
MONO_CARD=0000000000000000
MONO_NAME=Netik
