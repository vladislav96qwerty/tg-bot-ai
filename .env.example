# NeNetflixBot Configuration Example
# Rename this file to .env and fill in your values

# 1. Telegram Bot Token
BOT_TOKEN=your_bot_token_here

# 2. TMDB API Key (v3)
TMDB_API_KEY=your_tmdb_api_key_here

# 3. AI Providers (обов'язкові для рекомендацій)
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# 4. Channel Settings
CHANNEL_ID=-100xxxxxxxxxx
CHANNEL_USERNAME=@your_channel_username

# 5. Admin Settings
ADMIN_ID=your_id_here
ADMIN_IDS=id1,id2

# 6. Turso / libsql database (обов'язково для продакшну)
TURSO_DATABASE_URL=libsql://your-db-url-here
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# 7. Payment (Mock/Monobank)
MONO_CARD=0000000000000000
MONO_NAME=Netik
